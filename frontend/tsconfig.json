{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    // baseUrl is deprecated in TS 6 (removed in 7); paths resolve relative to
    // this tsconfig's directory, so anchor them at ./src explicitly.
    "paths": {
      "@components/*": ["./src/components/*"],
      "@routes/*": ["./src/routes/*"],
      "@styles/*": ["./src/styles/*"],
      "@assets/*": ["./src/assets/*"],
      "@backend/*": ["./src/backend/*"],
      "@pages/*": ["./src/pages/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@lib/*": ["./src/lib/*"],
    }
  }
}
