# Copy to .env for local dev (it's gitignored). In prod, supply these as real
# environment variables. Nested config keys use the .NET "__" convention.

# --- JWT (required) ---
# Base64-encoded 32+ byte HMAC-SHA256 key. Generate one with:
#   openssl rand -base64 32
Jwt__Key=
Jwt__Issuer=app
Jwt__Audience=app

# --- MongoDB (required) ---
MongoDB__ConnectionString=mongodb://localhost:27017
MongoDB__DatabaseName=app

# --- CORS (frontend origins allowed to call the API) ---
Cors__Origins__0=https://localhost:5173

# --- WebAuthn / FIDO2 (passkeys) ---
Fido2__ServerDomain=localhost
Fido2__ServerName=App
Fido2__Origins__0=https://localhost:5173

# --- RabbitMQ (optional; publishing degrades gracefully if absent) ---
RabbitMQ__HostName=localhost
RabbitMQ__Username=guest
RabbitMQ__Password=guest

# --- Grafana Loki log shipping (optional; console-only if unset) ---
Loki__Uri=
